# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://your-railway-or-cloudrun-url.com
WEBHOOK_URL=https://your-railway-or-cloudrun-url.com/webhook/bot
SESSION_SECRET=                    # openssl rand -hex 32
ADMIN_EMAIL=                       # your Google account email
PORT=3000

# ── Bot service (screenappai/meeting-bot container) ───────────────────────────
BOT_SERVICE_URL=https://your-bot-container-url.com
BOT_WEBHOOK_SECRET=                # openssl rand -hex 32  (shared with bot container)

# ── Firebase / GCP ────────────────────────────────────────────────────────────
# Option A — single JSON blob (easiest for Railway env vars)
FIREBASE_SERVICE_ACCOUNT=         # paste the full service account JSON as one line

# Option B — individual fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=              # PEM key, newlines as \n
FIREBASE_STORAGE_BUCKET=           # e.g. your-project.appspot.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Future: Google Meet transcription via Deepgram ────────────────────────────
# DEEPGRAM_API_KEY=                # see futureFixes.md
